#!/bin/sh

# ANSI color codes
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

echo "Running performance tests (Playwright) before push..."

# Run the tests. We use '|| true' so the hook itself doesn't exit with a failure code right away
if ! npm run test:perf; then
    echo ""
    echo "${YELLOW}================================================================${NC}"
    echo "${YELLOW}⚠️  WARNING: Performance tests failed! ⚠️${NC}"
    echo "${YELLOW}================================================================${NC}"
    echo "The Playwright performance benchmarks (npm run test:perf) did not pass."
    echo "This is just a warning. The push will still proceed."
    echo "Please review the test output above to check for regressions."
    echo "${YELLOW}================================================================${NC}"
    echo ""
else
    echo "Performance tests passed!"
fi

# Always exit 0 to allow the push
exit 0
